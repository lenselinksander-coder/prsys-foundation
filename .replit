run = "npm run install:all && npm run build:web && npm start"
entrypoint = "backend/src/server.ts"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm start"]
build = ["sh", "-c", "npm run install:all && npm run build:web"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001
