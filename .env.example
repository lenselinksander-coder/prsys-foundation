# PRSYS Foundation — Omgevingsvariabelen
# Kopieer dit bestand naar .env en vul de waarden in.
# Het .env bestand wordt NIET gecommit (staat in .gitignore).

# JWT-sleutel — gebruik een willekeurige, lange string in productie
JWT_SECRET=verander-mij-naar-een-veilige-sleutel

# Server poort (standaard: 5000)
PORT=5000

# Omgeving: 'development' of 'production'
NODE_ENV=development

# Anthropic API-sleutel (voor Claude / ORFHEUSS AI-analyses)
ANTHROPIC_API_KEY=sk-ant-...
